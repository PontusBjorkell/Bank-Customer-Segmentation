# Virtual environment
.venv/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/
*.egg-info/

# macOS
.DS_Store

# IDE
.vscode/

# Generated data
data/processed/*
data/database/*
data/exports/*

# Keep folder structure
!data/processed/.gitkeep
!data/database/.gitkeep
!data/exports/.gitkeep

# Raw datasets
data/raw/*.csv

# Reports generated by the pipeline
reports/figures/*
reports/sql/*
reports/statistical/*

!reports/figures/.gitkeep
!reports/sql/.gitkeep
!reports/statistical/.gitkeep